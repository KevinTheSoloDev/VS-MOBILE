    <string name="select">Select</string>
    <string name="storageProviderAuthorities">git.artdeell.dnboostrap.gamefiles</string>
    <style name="AppTheme" parent="@style/Theme.AppCompat">
        <item name="controlButtonStyle">@style/ControlButton</item>
        <item name="joystickStyle">@style/Joystick</item>
    </style>
    <style name="ControlButton">
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:background">#3f000000</item>
        <item name="android:width">64dp</item>
        <item name="android:height">64dp</item>
    </style>
    <style name="Joystick">
        <item name="android:background">#00000000</item>
    </style>
    <declare-styleable name="ControlButton">
        <attr format="integer" name="button_keycode"/>
        <attr format="integer" name="button_keycode2"/>
        <attr format="boolean" name="sticky"/>
        <attr format="boolean" name="cursorPassThru"/>
    </declare-styleable>
    <declare-styleable name="ControlGridLayout_LayoutParams">
        <attr format="enum" name="alignmentHorizontal">
            <enum name="left" value="0"/>
            <enum name="right" value="2"/>
            <enum name="center" value="4"/>
        </attr>
        <attr format="enum" name="alignmentVertical">
            <enum name="top" value="1"/>
            <enum name="bottom" value="3"/>
            <enum name="center" value="4"/>
        </attr>
        <attr format="integer" name="offsetHorizontal"/>
        <attr format="integer" name="offsetVertical"/>
    </declare-styleable>
